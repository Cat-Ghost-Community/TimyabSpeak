# TeamTP Environment Configuration
# Copy to .env and fill in values
# chmod 600 this file!

TS6_BASE_URL=http://127.0.0.1:10080
TS6_API_KEY=your-64-char-api-key
TS6_QUERY_HOST=127.0.0.1
TS6_QUERY_PORT=10022
TS6_QUERY_PASSWORD=your-query-admin-password

PANEL_PORT=3000
PANEL_BIND=127.0.0.1
PANEL_JWT_SECRET=change-this-to-random-hex
PANEL_REFRESH_SECRET=change-this-too
PANEL_ADMIN_USER=admin
PANEL_ADMIN_HASH=sha256-hash-of-your-password
