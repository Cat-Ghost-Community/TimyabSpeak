[Unit]
Description=TeamTP Level-Up Bot
After=teamspeak6.service
Wants=teamspeak6.service

[Service]
Type=simple
User=teamtp
Group=teamtp
WorkingDirectory=/opt/teamtp/bots/level-bot
ExecStart=/usr/bin/node /opt/teamtp/bots/level-bot/index.js
EnvironmentFile=/opt/teamtp/.env
Restart=on-failure
RestartSec=10
LimitNOFILE=16384

[Install]
WantedBy=multi-user.target
